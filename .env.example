# ============================================================
# AI Sports Arena — environment variables
# Copy to .env for local runs. In GitHub, set these as
# Actions SECRETS (keys) and VARIABLES (flags) — never commit real values.
# ============================================================

# --- Safety flags (GitHub Actions VARIABLES) ---
# DRY_RUN=true  -> agents decide and everything is logged/settled as paper
#                  trades, but NO real orders are sent to Kalshi.
# Defaults to true whenever unset — you must explicitly set false to go live.
DRY_RUN=true
# KILL_SWITCH=true halts all order placement immediately (overrides everything).
KILL_SWITCH=false
# Which Kalshi environment to trade against: prod | demo
KALSHI_ENV=prod

# --- Kalshi credentials (GitHub Actions SECRETS) ---
# Create at kalshi.com -> Account -> API Keys. You get a key ID and download
# a private key file once. Paste the PEM contents (multi-line) as the secret.
KALSHI_API_KEY_ID=your-key-id-here
# Either paste the PEM content directly...
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# ...or point at a local file (useful for local dev; file is gitignored)
KALSHI_PRIVATE_KEY_PATH=

# --- Model provider keys (GitHub Actions SECRETS) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
